# --- FabLIMS to NOMAD Sync Configuration ---

# 1. Provide your FabLIMS API Key
FABLIMS_API_KEY="your_fablims_api_key_here"

# 2. Provide your NOMAD Username and Password
NOMAD_USERNAME="your_nomad_username_here"
NOMAD_PASSWORD="your_nomad_password_here"

# 3. (Optional) Override the Target NOMAD API URL
# If left blank, it defaults to: https://oasis.ientrance.eu/nomad-oasis/api/v1
NOMAD_BASE_URL="your_target_nomad_api_url"
